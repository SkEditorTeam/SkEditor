<?xml version="1.0" encoding="utf-8"?>
<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:asyncImg="clr-namespace:AsyncImageLoader;assembly=AsyncImageLoader.Avalonia"
             xmlns:controls="using:SkEditor.Controls"
             xmlns:utils="using:SkEditor.Utilities"
             xmlns:icons="using:FluentIcons.Avalonia.Fluent"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="SkEditor.Controls.MarketplaceItem">

	<UserControl.Resources>
		<utils:NumberFormatConverter x:Key="NumberFormatConverter"/>
	</UserControl.Resources>

	<Design.PreviewWith>
		<controls:MarketplaceItem
                    ItemName="Analyzer"
                    IconUrl="https://github.com/SkEditorTeam/Marketplace/blob/main/items/Analyzer/Analyzer.png?raw=true"
                    Author="Glicz &amp; Notro"
                    Version="1.3.5"
                    LastUpdated="Mar 15, 2024"
                    Downloads="2547"
                    Description="Quickly identify errors in your scripts!"/>
	</Design.PreviewWith>

	<UserControl.Styles>
		<Style Selector="Border.iconBorder">
			<Setter Property="CornerRadius" Value="8"/>
			<Setter Property="Width" Value="72"/>
			<Setter Property="Height" Value="72"/>
			<Setter Property="HorizontalAlignment" Value="Center"/>
			<Setter Property="ClipToBounds" Value="True"/>
			<Setter Property="Background">
				<LinearGradientBrush>
					<GradientStop Offset="0" Color="#646464"/>
					<GradientStop Offset="1" Color="#505050"/>
				</LinearGradientBrush>
			</Setter>

			<Setter Property="Transitions">
				<Transitions>
					<BrushTransition Property="Background" Duration="0:0:0.25"/>
				</Transitions>
			</Setter>
		</Style>

		<Style Selector="asyncImg|AdvancedImage.icon">
			<Setter Property="Width" Value="72"/>
			<Setter Property="Height" Value="72"/>
			<Setter Property="Opacity" Value="0"/>
			<Setter Property="Source" Value="{Binding IconUrl}"/>
			<Setter Property="Transitions">
				<Transitions>
					<DoubleTransition Property="Opacity" Duration="0:0:0.25"/>
				</Transitions>
			</Setter>
		</Style>

		<Style Selector="Border.rootBorder">
			<Setter Property="CornerRadius" Value="8"/>
			<Setter Property="Width" Value="220"/>
			<Setter Property="Height" Value="280"/>
			<Setter Property="Background" Value="#0FFFFFFF"/>
			<Setter Property="Padding" Value="16"/>

			<Setter Property="Transitions">
				<Transitions>
					<BrushTransition Property="Background" Duration="0:0:0.25"/>
				</Transitions>
			</Setter>
		</Style>

		<Style Selector="Border.rootBorder:pointerover">
			<Setter Property="Background" Value="#1AFFFFFF"/>
			<Setter Property="Cursor" Value="Hand"/>
		</Style>
	</UserControl.Styles>

	<Border Classes="rootBorder">
		<DockPanel>
			<!-- Footer Info -->
			<StackPanel DockPanel.Dock="Bottom" Margin="0,12,0,0" Spacing="4">
				<StackPanel Orientation="Horizontal" Spacing="4">
					<icons:SymbolIcon Symbol="Person"
									FontSize="15"
									Foreground="#78FFFFFF"/>
					<TextBlock Text="{Binding Author}"
							 FontSize="12"
							 Foreground="#78FFFFFF"/>
				</StackPanel>

				<StackPanel Orientation="Horizontal" Spacing="4">
					<icons:SymbolIcon Symbol="Calendar"
									FontSize="15"
									Foreground="#78FFFFFF"/>
					<TextBlock Text="{Binding LastUpdated}"
							 FontSize="12"
							 Foreground="#78FFFFFF"/>
				</StackPanel>
			</StackPanel>

			<StackPanel>
				<!-- Icon -->
				<Border Name="IconBorder" Classes="iconBorder">
					<asyncImg:AdvancedImage Name="Icon" Classes="icon" RenderOptions.BitmapInterpolationMode="HighQuality"/>
				</Border>

				<!-- Title -->
				<TextBlock Text="{Binding ItemName}"
						  FontSize="18"
						  FontWeight="SemiBold"
						  Foreground="#FFFFFF"
						  HorizontalAlignment="Center"
						  Margin="0,12,0,0"/>

				<!-- Version with Downloads -->
				<StackPanel Orientation="Horizontal"
						  HorizontalAlignment="Center"
						  Margin="0,4,0,0"
						  Spacing="8">
					<TextBlock Text="{Binding Version}"
							 FontSize="13"
							 Foreground="#78FFFFFF"
							 FontWeight="Medium"/>

					<StackPanel Orientation="Horizontal" Spacing="2">
						<icons:SymbolIcon Symbol="ArrowDownload"
										  FontSize="13"
										  Foreground="#78FFFFFF"/>
						<TextBlock FontSize="13" Foreground="#78FFFFFF">
							<TextBlock.Text>
								<Binding Path="Downloads" Converter="{StaticResource NumberFormatConverter}" />
							</TextBlock.Text>
						</TextBlock>
					</StackPanel>
				</StackPanel>

				<!-- Description -->
				<TextBlock TextWrapping="Wrap"
						  Text="{Binding Description}"
						  FontSize="12"
						  Foreground="#BFFFFFFF"
						  Margin="0,12,0,0"
						  TextAlignment="Center"
						  Height="44"/>
			</StackPanel>
		</DockPanel>
	</Border>
</UserControl>